# =============================================================================
# PayPing server — environment variables
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# Required: MONGO_URI, JWT_SECRET, EMAIL_USER, EMAIL_PASS
# The server refuses to start if any required variable is missing or blank.
# =============================================================================

# Runtime environment. One of: development, test, production.
# In production, JWT_SECRET must be at least 32 chars and not a known weak value.
NODE_ENV=development

# HTTP port the API binds to. Defaults to 5000 when unset.
PORT=5000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection string. Use a dedicated database for each environment.
MONGO_URI=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for the dashboard frontend.
# In production, omit to deny all cross-origin requests.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Email (Nodemailer / Gmail transport)
# -----------------------------------------------------------------------------
# Gmail address used to send reminder emails.
EMAIL_USER=
# Gmail App Password (NOT the account password). Required by Nodemailer.
EMAIL_PASS=

# -----------------------------------------------------------------------------
# Optional — WhatsApp reminders (out of scope, kept for future phases)
# -----------------------------------------------------------------------------
ENABLE_WHATSAPP=false
WHATSAPP_API_KEY=